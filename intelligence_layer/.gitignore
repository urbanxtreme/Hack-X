# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment under the following line if you do.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may choose to ignore it.
#   Pipfile.lock

# poetry
#   Poetry uses pyproject.toml to manage dependencies, but lock file can be ignored.
#   poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml and local settings in .pdm-python.
.pdm-python
.pdm.toml
.pdm-build/

# PEP 582; dependency directories created by pipflow or pdm
